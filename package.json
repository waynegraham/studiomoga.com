{
  "name": "studiomoga.com",
  "version": "1.0.0",
  "description": "Minimalist portfolio website for Studio Moga, a design studio based in Toronto.",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm run build:css && concurrently \"pnpm run dev:eleventy\" \"pnpm run dev:css\"",
    "dev:eleventy": "eleventy --serve",
    "dev:css": "node ./scripts/tailwind-build.mjs --watch",
    "build:css": "node ./scripts/tailwind-build.mjs",
    "build": "pnpm run build:css && eleventy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
